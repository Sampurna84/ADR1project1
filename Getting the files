         echo "prefetch successfully done for $sra"
        echo "Starting fastq processing"
        fasterq-dump "$sra" --outdir "$ref"/FCfiles_YoungAd --skip-technical --readids --read-filter pass --dumpbase --split-3 --clip "$sra"
        echo "fastqc done successfully for $sra"
done

echo "prefetch sra for L4 data"
for sra in SRR6739752 SRR6739753 SRR6739754 SRR6739734 SRR6739735 SRR6739736
 do
       echo "Starting processing for $sra"
        echo "----------------------------"
