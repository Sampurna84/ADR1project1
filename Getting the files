        fastq-dump --outdir "$ref"/FCfiles_L4 --skip-technical --readids --read-filter pass --dumpbase --split-3 --clip "$sra"
        echo "fastqc done successfully for $sra"
done

echo "prefetch sra for embryo data"
for sra in SRR6739748 SRR6739749 SRR6739750 SRR6739731 SRR6739732 SRR6739733
 do
       echo "Starting processing for $sra"
        echo "----------------------------"
        prefetch "$sra"
         echo "prefetch successfully done for $sra"
        echo "Starting fastq processing"
        fastq-dump --outdir "$ref"/FCfiles_embryo --skip-technical --readids --read-filter pass --dumpbase --split-3 --clip "$sra"
        echo "fastqc done successfully for $sra"
done
