# Unload system perl for compatibility with entrez-directmodule unload perl
echo "indexing genome"
# Variables
#these are the links for downloading genome but I have uploaded the reference genome in the files
#ASSEMBLY='https://downloads.wormbase.org/releases/WS275/species/c_elegans/PRJNA13758/c_elegans.PRJNA13758.WS275.genomic.fa.gz'
#ANNOTATION='https://downloads.wormbase.org/releases/WS275/species/c_elegans/PRJNA13758/c_elegans.PRJNA13758.WS275.genomic.fa.gz'

# Make genome directory
mkdir -p "$ref"/genomefiles

# Download and unpack genome assembly
#wget $ASSEMBLY
gunzip -c "$ref"/genome/assembly.fa.gz > "$ref"/genomefiles/assembly.fasta

# Download and unpack genome annotation
#wget $ANNOTATION
gunzip -c "$ref"/genome/annotation.gtf.gz > "$ref"/genomefiles/annotation.gtf

# Create STAR index directory
mkdir -p "$ref"/genomefiles/index

# Generate STAR genome index
STAR \
  --runThreadN 8 \
  --runMode genomeGenerate \
  --genomeDir "$ref"/genomefiles/index \
  --genomeFastaFiles "$ref"/genomefiles/assembly.fasta \
  --sjdbGTFfile "$ref"/genomefiles/annotation.gtf \
  --genomeSAindexNbases 12

# Make output directories
mkdir -p "$ref"/results_all/aligned
mkdir -p "$ref"/results_all/counts


# Path to FASTQ files
###########################
## Align Reads to Genome ##
###########################

# Create an output directory for aligned and count reads.

mkdir -p "$ref"/results_all/aligned/embryo
mkdir -p "$ref"/results_all/aligned/L4
mkdir -p "$ref"/results_all/aligned/YoungAd
mkdir -p "$ref"/results_all/aligned/adult
mkdir -p "$ref"/results_all/counts/embryo
mkdir -p "$ref"/results_all/counts/L4
mkdir -p "$ref"/results_all/counts/YoungAd
mkdir -p "$ref"/results_all/counts/adult


# Align the reads.
#Align the reads for embryo data
# Path to FASTQ files
FASTQ_DIR="/N/scratch/duttasam/ADR1_P/FCfiles_embryo"


 # Align the reads (single-end)
for FASTQ in $FASTQ_DIR/*_pass.fastq; do
  PREFIX="$ref"/results_all/aligned/embryo/$(basename $FASTQ)
  STAR \
    --runThreadN 8 \
    --outFilterMultimapNmax 1 \
    --outFilterScoreMinOverLread .66 \
    --outFilterMismatchNmax 10 \
    --outFilterMismatchNoverLmax .3 \
    --runMode alignReads \
    --genomeDir "$ref"/genomefiles/index \
    --readFilesIn $FASTQ \
    --outFileNamePrefix $PREFIX \
    --outSAMattributes All \
    --outSAMtype BAM SortedByCoordinate
done

# Indexing the BAM files.

BAMS=($(find "$ref"//results_all/aligned/embryo -name "*\.bam"))

for BAM in ${BAMS[@]}; do
  samtools index $BAM
  done

  ####################
## Count Features ##
####################

# Create an output directory for read counts.
# Count reads.
BAMS=$(find "$ref"//results_all/aligned/embryo -name "*\.bam")

featureCounts \
  -a "$ref"/genomefiles/annotation.gtf \
  -o "$ref"/results_all/counts/counts_embryo.tsv \
  -t gene \
  -g gene_id \
  --largestOverlap \
  --readExtension3 150 \
  --primary \
  -s 2 \
  -T 8 \
  ${BAMS}

